API historique

Ajouter la route /history
// Route historique séances
fastify.post("/history", (request, reply) => {

    // Données envoyées
    const body = request.body as any;


    // Recherche utilisateur
    const user = database
        .prepare(`
            SELECT *
            FROM users
            WHERE login = ?
        `)
        .get(body.login) as any;


    // Vérifie utilisateur existe
    if(!user)
    {
        reply.status(404).send({
            message : "Utilisateur introuvable"
        });

        return;
    }


    // Vérifie password
    const passwordValid = bcrypt.compareSync(
        body.password,
        user.password
    );


    // Mauvais password
    if(!passwordValid)
    {
        reply.status(401).send({
            message : "Mot de passe incorrect"
        });

        return;
    }


    // Récupération historique
    const sessions = database
        .prepare(`
            SELECT
                start_time,
                end_time
            FROM sessions
            WHERE user_id = ?
        `)
        .all(user.id);


    // Retour données
    reply.send(sessions);

});

