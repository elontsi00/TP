API “Début séance”
Ajouter la route /start-session, avant fastify.listen()
// Route début séance
fastify.post("/start-session", (request, reply) => {

    // Récupération données frontend
    const body = request.body as any;


    // Recherche utilisateur
    const user = database
        .prepare(`
            SELECT *
            FROM users
            WHERE login = ?
        `)
        .get(body.login) as any;


    // Vérifie utilisateur existe
    if(!user)
    {
        reply.status(404).send({
            message : "Utilisateur introuvable"
        });

        return;
    }


    // Vérification mot de passe
    const passwordValid = bcrypt.compareSync(
        body.password,
        user.password
    );


    // Mauvais mot de passe
    if(!passwordValid)
    {
        reply.status(401).send({
            message : "Mot de passe incorrect"
        });

        return;
    }


    // Vérifie séance déjà ouverte
    const openedSession = database
        .prepare(`
            SELECT *
            FROM sessions
            WHERE user_id = ?
            AND end_time IS NULL
        `)
        .get(user.id);


    // Si séance déjà en cours
    if(openedSession)
    {
        reply.status(400).send({
            message : "Une séance est déjà en cours"
        });

        return;
    }


    // Heure actuelle
    const currentDate = new Date().toLocaleString();


    // Création séance
    database.prepare(`
        INSERT INTO sessions(
            user_id,
            start_time,
            end_time
        )
        VALUES (?, ?, ?)
    `)
    .run(
        user.id,
        currentDate,
        null
    );


    // Succès
    reply.send({
        message : "Séance démarrée"
    });

});

